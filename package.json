{
  "name": "@expressots/core",
  "version": "4.0.0",
  "description": "Expressots - modern, fast, lightweight nodejs web framework (@core)",
  "author": "Richard Zampieri",
  "main": "./lib/cjs/index.js",
  "types": "./lib/cjs/types/index.d.ts",
  "exports": {
    ".": {
      "import": {
        "types": "./lib/cjs/types/index.d.ts",
        "default": "./lib/esm/index.mjs"
      },
      "require": {
        "types": "./lib/cjs/types/index.d.ts",
        "default": "./lib/cjs/index.js"
      }
    },
    "./testing": {
      "import": {
        "types": "./lib/cjs/types/testing/index.d.ts",
        "default": "./lib/esm/testing/index.js"
      },
      "require": {
        "types": "./lib/cjs/types/testing/index.d.ts",
        "default": "./lib/cjs/testing/index.js"
      }
    },
    "./di": {
      "import": {
        "types": "./lib/cjs/types/di/inversify.d.ts",
        "default": "./lib/esm/di/inversify.js"
      },
      "require": {
        "types": "./lib/cjs/types/di/inversify.d.ts",
        "default": "./lib/cjs/di/inversify.js"
      }
    },
    "./render": {
      "import": {
        "types": "./lib/cjs/types/render/index.d.ts",
        "default": "./lib/esm/render/index.js"
      },
      "require": {
        "types": "./lib/cjs/types/render/index.d.ts",
        "default": "./lib/cjs/render/index.js"
      }
    },
    "./path-resolver": {
      "import": {
        "types": "./lib/cjs/types/path-resolver/index.d.ts",
        "default": "./lib/esm/path-resolver/index.js"
      },
      "require": {
        "types": "./lib/cjs/types/path-resolver/index.d.ts",
        "default": "./lib/cjs/path-resolver/index.js"
      }
    }
  },
  "sideEffects": [
    "./lib/**/application/application-container.js",
    "./lib/**/authorization/guard-decorators.js",
    "./lib/**/authorization/guard-registry.js",
    "./lib/**/db-in-memory/schema/decorators.js",
    "./lib/**/di/binding-decorator/decorator/provide.js",
    "./lib/**/di/binding-decorator/factory/module_factory.js",
    "./lib/**/error/exception-filter-decorators.js",
    "./lib/**/error/exception-filter-registry.js",
    "./lib/**/event/event-decorators.js",
    "./lib/**/interceptor/interceptor-decorators.js",
    "./lib/**/interceptor/interceptor-registry.js",
    "./lib/**/testing/mock-provider.js",
    "./lib/**/validation/adapters/class-validator.adapter.js",
    "./lib/**/validation/type-inference.js",
    "./lib/**/validation/validation-registry.js",
    "./lib/**/dto-validator/dto-validator.provider.js"
  ],
  "files": [
    "README.md",
    "LICENSE.md",
    "CHANGELOG.md",
    "llms.txt",
    "lib/**/*"
  ],
  "license": "MIT",
  "homepage": "https://expresso-ts.com",
  "funding": {
    "type": "github",
    "url": "https://github.com/sponsors/expressots"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/expressots/expressots"
  },
  "bugs": {
    "url": "https://github.com/expressots/expressots/issues"
  },
  "publishConfig": {
    "access": "public"
  },
  "engines": {
    "node": ">=20.19.0"
  },
  "keywords": [
    "expressots",
    "nodejs",
    "microservices",
    "typescript",
    "clean-architecture",
    "typescript-framework",
    "framework",
    "server-side"
  ],
  "scripts": {
    "prepare": "husky",
    "clean": "node scripts/rm.js lib",
    "copy": "node scripts/copy.js package.json README.md CHANGELOG.md lib",
    "sync-version": "node scripts/sync-version.js",
    "build": "npm run clean && npm run sync-version && npm run build:cjs && npm run build:esm && npm run copy",
    "build:esm": "node scripts/build-esm.js",
    "build:cjs": "tsc -p tsconfig.cjs.json",
    "prepublishOnly": "node scripts/release/guard-no-file-deps.mjs",
    "release": "release-it",
    "release:prepare": "node scripts/release/prepare-publish.mjs",
    "release:restore": "node scripts/release/restore-package-json.mjs",
    "release:publish": "npm run build && npm run release:prepare && npm publish --tag next --access public && npm run release:restore",
    "test": "jest",
    "test:watch": "jest --watch",
    "coverage": "jest --coverage",
    "format": "prettier --write \"packages/**/*.ts\" --cache",
    "lint": "eslint \"packages/**/*.ts\" --cache --cache-location node_modules/.cache/eslint/",
    "lint:fix": "eslint \"packages/**/*.ts\" --fix --cache --cache-location node_modules/.cache/eslint/",
    "docs:generate": "node scripts/generate-docs.js",
    "docs:clean": "node scripts/rm.js docs"
  },
  "dependencies": {
    "@expressots/shared": "^4.0.0",
    "reflect-metadata": "0.2.2"
  },
  "peerDependencies": {
    "class-validator": ">=0.14.0",
    "express": ">=5.0.0",
    "yup": ">=1.0.0",
    "zod": ">=3.22.0"
  },
  "peerDependenciesMeta": {
    "class-validator": {
      "optional": true
    },
    "express": {
      "optional": true
    },
    "yup": {
      "optional": true
    },
    "zod": {
      "optional": true
    }
  },
  "overrides": {
    "js-yaml": "4.2.0"
  },
  "devDependencies": {
    "@commitlint/cli": "19.2.1",
    "@commitlint/config-conventional": "19.1.0",
    "@release-it/conventional-changelog": "^11.0.0",
    "@types/express": "4.17.21",
    "@types/jest": "^29.5.14",
    "@types/node": "20.14.10",
    "@typescript-eslint/eslint-plugin": "8.65.0",
    "@typescript-eslint/parser": "7.16.0",
    "eslint": "8.57.0",
    "eslint-config-prettier": "9.1.0",
    "husky": "9.0.11",
    "jest": "29.7.0",
    "lint-staged": "^15.2.10",
    "prettier": "3.3.3",
    "release-it": "^20.0.1",
    "ts-jest": "29.2.5",
    "ts-node": "10.9.2",
    "typedoc": "^0.28.15",
    "typescript": "5.5.3",
    "zod": "^4.4.3"
  },
  "lint-staged": {
    "packages/**/*.ts": [
      "eslint --cache --cache-location node_modules/.cache/eslint/ --fix",
      "prettier --write --cache"
    ]
  },
  "release-it": {
    "git": {
      "commitMessage": "chore(release): ${version}"
    },
    "github": {
      "release": true
    },
    "npm": {
      "publish": false
    },
    "plugins": {
      "@release-it/conventional-changelog": {
        "infile": "CHANGELOG.md",
        "preset": {
          "name": "conventionalcommits",
          "types": [
            {
              "type": "feat",
              "section": "Features"
            },
            {
              "type": "fix",
              "section": "Bug Fixes"
            },
            {
              "type": "perf",
              "section": "Performance Improvements"
            },
            {
              "type": "revert",
              "section": "Reverts"
            },
            {
              "type": "docs",
              "section": "Documentation"
            },
            {
              "type": "refactor",
              "section": "Code Refactoring"
            },
            {
              "type": "test",
              "section": "Tests"
            },
            {
              "type": "build",
              "section": "Build System"
            },
            {
              "type": "ci",
              "section": "Continuous Integrations"
            },
            {
              "type": "chore",
              "hidden": true
            }
          ]
        }
      }
    }
  }
}
